# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ===========================================
# SENSITIVE INFORMATION & SECRETS
# ===========================================
# Never commit real API keys, tokens, or credentials.
# This project stores the OpenRouter API key only in browser localStorage (via Zustand).
# Protect any .env or secret files.

# Environment variables (all variants)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# Allow example/template files (safe to commit)
!.env.example
!.env*.example

# API keys, tokens, and credentials (common patterns)
*api-key*
*apikey*
*openrouter*
*secret*
*token*
*password*
credentials.json
auth.json

# Private keys and certificates
*.pem
*.key
*.crt
id_rsa*
id_dsa*
*.p12
*.pfx

# Secret directories
secrets/
config/secrets/
private/

# ===========================================
# STANDARD NEXT.JS + PROJECT IGNORES
# ===========================================

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ===========================================
# ADDITIONAL SECURITY / DEV IGNORES
# ===========================================

# IDE and editor settings (may contain personal paths or secrets)
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS generated files
Thumbs.db
ehthumbs.db

# Logs and temporary files
*.log
*.tmp
*.temp
.cache/

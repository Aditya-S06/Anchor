# PinBoard Environment Configuration
# Copy this file to .env.local and fill in your values
# 
# ⚠️  NEVER commit your actual .env.local file — it is ignored by git
# 
# Get your OpenRouter API key (free tier available):
# https://openrouter.ai/keys

# ===========================================
# AI Configuration (OpenRouter)
# ===========================================

# Your OpenRouter API key
OPENROUTER_API_KEY=sk-or-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Default AI model to use for vision and planning
# Recommended free vision model:
DEFAULT_AI_MODEL=qwen/qwen-2.5-vl-7b-instruct:free

# Alternative models (uncomment to use):
# DEFAULT_AI_MODEL=qwen/qwen-2.5-vl-7b-instruct
# DEFAULT_AI_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
# DEFAULT_AI_MODEL=qwen/qwen-2.5-vl-32b-instruct:free

# ===========================================
# Optional Settings
# ===========================================

# App name (used in metadata)
NEXT_PUBLIC_APP_NAME=PinBoard

# Base URL (useful for deployment)
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
